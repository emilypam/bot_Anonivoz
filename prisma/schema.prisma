generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum InformantType {
  VICTIM
  WITNESS
}

enum HarassmentType {
  PHYSICAL
  VERBAL
  SOCIAL
  CYBERBULLYING
}

enum FrequencyLevel {
  ONCE
  WEEKLY
  DAILY
}

enum LocationTag {
  CLASSROOM
  RECESS
  SOCIAL_MEDIA
  OUTSIDE
}

enum IncidentDateApprox {
  TODAY
  YESTERDAY
  THIS_WEEK
  LAST_WEEK
  OVER_A_MONTH
}

enum ReportStatus {
  PENDING
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DeceRole {
  COUNSELOR
  COORDINATOR
  DIRECTOR
}

// ─── Tablas ───────────────────────────────────────────────────────────────────

// Super administrador global del sistema (accede a todas las instituciones)
model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   @default("")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// Institución educativa (Fe y Alegría)
model Institution {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique   // Código único para el deep link del bot
  city      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   DeceMember[]
  reports   Report[]
  botEvents BotEvent[]

  @@index([code])
  @@index([active])
}

// Personal del DECE — pertenece a una institución
model DeceMember {
  id            String       @id @default(uuid())
  institutionId String?
  name          String
  email         String       @unique
  password      String       @default("")
  role          DeceRole     @default(COUNSELOR)
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  institution   Institution? @relation(fields: [institutionId], references: [id])
  assignedReports Report[]   @relation("AssignedTo")
  notes           CaseNote[]
  statusChanges   StatusHistory[]

  @@index([email])
  @@index([active])
  @@index([institutionId])
}

// Reporte principal — pertenece a una institución
model Report {
  id             String        @id @default(uuid())
  reportNumber   Int           @unique @default(autoincrement())
  institutionId  String?
  telegramUserId String
  informantType  InformantType
  wantsContact   Boolean       @default(false)
  previousReport Boolean       @default(false)
  status         ReportStatus  @default(PENDING)
  priority       Priority      @default(MEDIUM)
  assignedToId   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  institution   Institution?    @relation(fields: [institutionId], references: [id])
  assignedTo    DeceMember?     @relation("AssignedTo", fields: [assignedToId], references: [id])
  incident      Incident?
  aggressors    Aggressor[]
  witnesses     Witness[]
  evidence      Evidence[]
  notes         CaseNote[]
  statusHistory StatusHistory[]

  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([informantType])
  @@index([assignedToId])
  @@index([telegramUserId])
  @@index([institutionId])
}

model Incident {
  id                 String             @id @default(uuid())
  reportId           String             @unique
  harassmentType     HarassmentType
  frequencyLevel     FrequencyLevel
  locationTag        LocationTag
  incidentDateApprox IncidentDateApprox
  description        String             @db.Text
  createdAt          DateTime           @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([harassmentType])
  @@index([frequencyLevel])
  @@index([locationTag])
}

model Aggressor {
  id          String   @id @default(uuid())
  reportId    String
  description String   @db.Text
  createdAt   DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model Witness {
  id          String   @id @default(uuid())
  reportId    String
  description String   @db.Text
  createdAt   DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model Evidence {
  id        String   @id @default(uuid())
  reportId  String
  url       String
  createdAt DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model CaseNote {
  id        String   @id @default(uuid())
  reportId  String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  report Report     @relation(fields: [reportId], references: [id], onDelete: Cascade)
  author DeceMember @relation(fields: [authorId], references: [id])

  @@index([reportId])
  @@index([authorId])
}

model StatusHistory {
  id          String        @id @default(uuid())
  reportId    String
  changedById String?
  oldStatus   ReportStatus?
  newStatus   ReportStatus
  notes       String?       @db.Text
  changedAt   DateTime      @default(now())

  report    Report      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  changedBy DeceMember? @relation(fields: [changedById], references: [id])

  @@index([reportId])
  @@index([changedAt])
}

model TelegramSession {
  key       String   @id
  data      String   @db.Text
  updatedAt DateTime @updatedAt
}

enum BotEventType {
  BOT_START
  REPORT_STARTED
  REPORT_COMPLETED
  REPORT_ABANDONED
  SUPPORT_STARTED
}

model BotEvent {
  id             String       @id @default(uuid())
  telegramUserId String
  institutionId  String?
  eventType      BotEventType
  createdAt      DateTime     @default(now())

  institution Institution? @relation(fields: [institutionId], references: [id])

  @@index([telegramUserId])
  @@index([eventType])
  @@index([createdAt])
  @@index([institutionId])
}
