# Database
DATABASE_URL="postgresql://user:password@host:5432/database"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your_bot_token_here"

# Webhook
WEBHOOK_URL="https://yourdomain.vercel.app/bot/webhook"
